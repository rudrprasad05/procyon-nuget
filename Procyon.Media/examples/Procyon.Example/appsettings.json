{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=media.db"
  },
  "Procyon": {
    "Media": {
      "Provider": "S3",
      "EnableHashing": true,
      "DefaultFolder": "nuget",
      "BaseUrl": "https://mctechfiji.s3.us-east-1.amazonaws.com",
      "S3": {
        "Bucket": "mctechfiji"
      }
    }
  }
}
